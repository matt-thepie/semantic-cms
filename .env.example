# Admin sign-in — use Google sign-in, a shared password, or both.
SESSION_SECRET=a-long-random-string

# Option A: Google sign-in (recommended — no passwords to manage).
# Create an OAuth 2.0 "Web application" client at https://console.cloud.google.com/apis/credentials
# Add this Authorized redirect URI:  https://YOUR-ADMIN-DOMAIN/api/auth/google/callback
# Then list the Google accounts allowed to administer the site:
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
# ADMIN_EMAILS=alice@gmail.com,matt@gmail.com

# Option B: a single shared admin password (only needed if NOT using Google).
# ADMIN_PASSWORD=changeme

# LLM — pick one adapter: anthropic | openai | ollama
LLM_ADAPTER=anthropic
LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6   # optional override

# Unsplash — for AI image search (optional)
# Get a free Access Key at https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your-access-key

# Storage — pick one adapter: local | r2 | s3 | backblaze
STORAGE_ADAPTER=local
# STORAGE_BUCKET=my-bucket
# STORAGE_ACCOUNT_ID=your-r2-account-id      # R2 only
# STORAGE_ACCESS_KEY_ID=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_PUBLIC_URL=https://assets.example.com
# STORAGE_REGION=us-east-1                   # S3 / Backblaze only

# SMTP (optional — needed for contact form)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=yourpassword
# SMTP_FROM=you@example.com
# SMTP_TO=you@example.com

# Database path (default: ./data/cms.db)
# DB_PATH=./data/cms.db
